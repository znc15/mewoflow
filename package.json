{
  "name": "mewoflow",
  "version": "0.2.19",
  "description": "Local Claude Code workflow gates for research, grill, planning, implementation, verification, and archive.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mewoflow": "dist/src/cli.js"
  },
  "files": [
    "dist/src/",
    "docs/mewoflow-logo.svg",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude-code",
    "hooks",
    "workflow",
    "cli",
    "agent"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "smoke:dist": "node dist/src/cli.js --version && node dist/src/cli.js help",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run build",
    "verify": "npm run typecheck && npm test && npm run build && npm run smoke:dist && npm run pack:dry"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^3.2.4"
  }
}
